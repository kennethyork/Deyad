{
  "name": "deyad",
  "productName": "Deyad",
  "version": "1.7.7",
  "description": "Local AI app builder powered by Ollama models",
  "repository": {
    "type": "git",
    "url": "https://github.com/kennethhy/Deyad"
  },
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "dev": "npm run build:main && npm run build:preload && (trap 'kill 0' EXIT; vite --config vite.renderer.config.ts & sleep 2 && VITE_DEV_SERVER_URL=http://localhost:9245 electron .)",
    "start": "npm run build:all --silent && electron .",
    "build:main": "vite build --config vite.main.config.ts --logLevel error",
    "build:preload": "vite build --config vite.preload.config.ts --logLevel error",
    "build:renderer": "vite build --config vite.renderer.config.ts --logLevel error",
    "build:all": "npm run build:main --silent && npm run build:preload --silent && npm run build:renderer --silent",
    "build": "npm run build:all",
    "dist": "npm run build:all && electron-builder",
    "dist:linux": "npm run build:all && electron-builder --linux",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:all": "npm run build:all && electron-builder --linux --win",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:e2e": "npm run build:all && npx playwright test",
    "typecheck": "tsc --noEmit",
    "analyze": "npm run build:all && echo '=== Bundle Sizes ===' && du -sh .vite/build/*.js 2>/dev/null && du -sh .vite/renderer/*.js 2>/dev/null; echo '=== Renderer Assets ===' && find .vite/renderer -name '*.js' -o -name '*.css' | xargs ls -lhS 2>/dev/null | head -20"
  },
  "keywords": [
    "ollama",
    "ai",
    "app-builder",
    "electron"
  ],
  "author": {
    "name": "Deyad",
    "email": "maintainer@deyad.app"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^24.0.0",
    "electron-installer-appimage": "*",
    "electron-installer-dmg": "*",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "happy-dom": "^20.0.0",
    "typescript": "^6.0.2",
    "vite": "^5.4.21",
    "vitest": "^3.1.1",
    "ws": "^8.18.0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "fix-path": "^5.0.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.1",
    "update-electron-app": "^3.1.2",
    "xterm": "^5.0.1",
    "xterm-addon-fit": "^0.7.0"
  }
}
